# --- MODULE 5: Website Intelligence ---
def module_website_intelligence():
    console.print(Panel("Module 5: Website Technology & Security Header Extraction", style="accent"))
    target_url = input("Enter target website host configuration (e.g., example.com) > ").strip()
    
    if not target_url.startswith("http"):
        target_url = "https://" + target_url

    results = {}
    with Progress(SpinnerColumn(), TextColumn("[progress.description]{task.description}"), transient=True) as progress:
        progress.add_task(description="Executing socket requests and auditing target headers...", total=None)
        
        try:
            req = urllib.request.Request(target_url, headers={'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) GhostHound/1.0'})
            context = ssl._create_unverified_context()
            with urllib.request.urlopen(req, context=context, timeout=6) as response:
                headers = dict(response.info())
                
                results["Server Architecture"] = headers.get("Server", "Hidden/Undetected")
                results["X-Frame-Options"] = headers.get("X-Frame-Options", "MISSING (Vulnerable to Clickjacking)")
                results["Content-Security-Policy"] = "Configured" if "Content-Security-Policy" in headers else "MISSING"
                results["X-Content-Type-Options"] = headers.get("X-Content-Type-Options", "MISSING")
                results["Strict-Transport-Security (HSTS)"] = "Active" if "Strict-Transport-Security" in headers else "MISSING"
                
                powered_by = headers.get("X-Powered-By", "")
                results["Backend Ecosystem"] = powered_by if powered_by else "Undisclosed Framework"
                
        except Exception as e:
            log_error(f"Host endpoint verification crashed: {str(e)}")
            return

    SESSION_DATA["website_intelligence"][target_url] = results

    table = Table(title=f"Web Vector Metrics: {target_url}", border_style="accent")
    table.add_column("Header Directive / Element", style="info")
    table.add_column("Detected Target Parameter", style="white")
    for k, v in results.items():
        table.add_row(k, v)
    console.print(table)
    log_success("Target surface mapping compiled.")

# --- MODULE 6: DNS & WHOIS Lookup ---
def module_dns_whois_lookup():
    console.print(Panel("Module 6: DNS Map & Domain WHOIS Intelligence", style="accent"))
    domain = input("Enter clean domain for lookup (e.g., target.com) > ").strip()
    if not domain:
        return

    dns_payload = {}
    record_types = ["A", "AAAA", "MX", "TXT", "NS", "CNAME"]

    with Progress(SpinnerColumn(), TextColumn("[progress.description]{task.description}"), transient=True) as progress:
        progress.add_task(description="Interrogating primary zones and registry records...", total=None)
        
        for rec in record_types:
            try:
                ans = dns.resolver.resolve(domain, rec)
                dns_payload[f"{rec} Records"] = "\n".join([r.to_text() for r in ans])
            except Exception:
                dns_payload[f"{rec} Records"] = "No active zone entries listed"

        try:
            whois_data = whois.whois(domain)
            dns_payload["Domain Registrar"] = str(whois_data.registrar)
            dns_payload["Creation Timestamp"] = str(whois_data.creation_date)
            dns_payload["Expiration Boundary"] = str(whois_data.expiration_date)
        except Exception as e:
            dns_payload["WHOIS Status"] = f"Query dropped or rate-limited: {str(e)}"

    SESSION_DATA["dns_whois_lookup"][domain] = dns_payload

    table = Table(title=f"Zone and Registrar Profile: {domain}", border_style="accent")
    table.add_column("Registry Vector", style="info")
    table.add_column("Resolved Record Value", style="white")
    for k, v in dns_payload.items():
        display_val = str(v)[:80] + "..." if len(str(v)) > 80 else str(v)
        table.add_row(k, display_val)
    console.print(table)
    log_success("Domain lookup mappings collected.")

