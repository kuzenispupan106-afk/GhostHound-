# --- MODULE 1: IP Intelligence ---
def module_ip_intelligence():
    if not check_credentials(): return
    console.print(Panel("Module 1: IP Intelligence Subsystem", style="accent"))
    ip = input("Select Target IP address > ").strip()
    try:
        ipaddress.ip_address(ip)
    except ValueError:
        log_error("Target validation error: Invalid IP syntax.")
        return

    with Progress(SpinnerColumn(), TextColumn("[progress.description]{task.description}"), transient=True) as progress:
        progress.add_task(description="Querying IPinfo Intelligence Infrastructure...", total=None)
        
        try:
            url = f"https://ipinfo.io/{ip}/json?token={IPINFO_API_KEY}"
            req = urllib.request.Request(url, headers={'User-Agent': 'GhostHound/1.0'})
            with urllib.request.urlopen(req, timeout=6) as response:
                res_data = json.loads(response.read().decode())
        except Exception as e:
            log_error(f"Network Timeout/Handshake Failure: {str(e)}")
            return

    if "error" in res_data:
        log_error(f"Registry Refusal: {res_data['error'].get('title', 'Unauthorized token parameters')}")
        return

    results = {
        "Public IP Target": ip,
        "Country": res_data.get("country", "N/A"),
        "Region / Province": res_data.get("region", "N/A"),
        "City": res_data.get("city", "N/A"),
        "ISP Identity": res_data.get("org", "N/A"),
        "Postal Code": res_data.get("postal", "N/A"),
        "Coordinates": res_data.get("loc", "N/A"),
        "Reverse DNS Map": "N/A"
    }

    try:
        results["Reverse DNS Map"] = socket.gethostbyaddr(ip)[0]
    except Exception:
        pass

    SESSION_DATA["ip_intelligence"][ip] = results

    table = Table(title=f"IP Intel Metrics: {ip}", border_style="accent")
    table.add_column("Telemetry Component", style="info")
    table.add_column("Discovered Mapping", style="white")
    for key, val in results.items():
        table.add_row(key, str(val))
    console.print(table)
    log_success("Data extraction finalized cleanly via IPinfo database.")

# --- MODULE 2: Phone Number Info ---
def module_phone_number_info():
    console.print(Panel("Module 2: Phone Number Intelligence Lookup", style="accent"))
    phone_in = input("Enter target phone string (Include country code e.g., +14155552671) > ").strip()
    
    try:
        parsed_num = phonenumbers.parse(phone_in, None)
        if not phonenumbers.is_valid_number(parsed_num):
            log_error("Integrity error: Phone entry string is invalid for standard routing.")
            return

        with Progress(SpinnerColumn(), TextColumn("[progress.description]{task.description}"), transient=True) as progress:
            progress.add_task(description="Extracting localized carrier and zone records...", total=None)
            
            carrier_name = carrier.name_for_number(parsed_num, "en")
            location = geocoder.description_for_number(parsed_num, "en")
            tz_data = timezone.time_zones_for_number(parsed_num)
            type_code = phonenumbers.number_type(parsed_num)
            
            type_map = {0: "FIXED_LINE", 1: "MOBILE", 2: "FIXED_LINE_OR_MOBILE", 3: "TOLL_FREE", 4: "PREMIUM_RATE"}
            resolved_type = type_map.get(type_code, "UNKNOWN/VOIP")

        results = {
            "Normalized String": phone_in,
            "Target Country/Zone": location or "Undetermined",
            "Carrier Matrix": carrier_name or "Landline / Virtual Provider",
            "Registered Timezone": ", ".join(tz_data),
            "Line Classification": resolved_type
        }
        SESSION_DATA["phone_info"][phone_in] = results

        table = Table(title=f"Telephony Breakdown: {phone_in}", border_style="accent")
        table.add_column("Metric Class", style="info")
        table.add_column("Registry Payload", style="white")
        for k, v in results.items():
            table.add_row(k, v)
        console.print(table)
        log_success("Telephony data compiled.")
    except Exception as e:
        log_error(f"Parsing runtime failure: {str(e)}")

# --- MODULE 3: Username Hunter ---
async def fetch_target_profile(session, username, site_name, format_url):
    target = format_url.format(username)
    try:
        async with session.get(target, timeout=5, headers={"User-Agent": "Mozilla/5.0"}) as resp:
            if resp.status == 200:
                return site_name, target
    except Exception:
        pass
    return None

def module_username_hunter():
    console.print(Panel("Module 3: Async Username Hunter", style="accent"))
    username = input("Enter target identity handle/alias > ").strip()
    if not username:
        return

    target_registry = {
        "GitHub Platform": "https://github.com/{}",
        "Twitter / X": "https://twitter.com/{}",
        "Instagram Core": "https://www.instagram.com/{}",
        "Reddit Directory": "https://www.reddit.com/user/{}",
        "Pinterest Vault": "https://www.pinterest.com/{}/",
        "DeviantArt": "https://www.deviantart.com/{}"
    }

    async def execute_async_sweep():
        import aiohttp
        async with aiohttp.ClientSession() as session:
            tasks = [fetch_target_profile(session, username, name, url) for name, url in target_registry.items()]
            return await asyncio.gather(*tasks)

    log_info(f"Initiating high-concurrency sweep for matching aliases: '{username}'")
    with Progress(SpinnerColumn(), TextColumn("[progress.description]{task.description}"), transient=True) as progress:
        progress.add_task(description="Querying server clusters asynchronously...", total=None)
        raw_output = asyncio.run(execute_async_sweep())
        active_matches = [match for match in raw_output if match]

    if active_matches:
        table = Table(title=f"Discovered Profiles: {username}", border_style="accent")
        table.add_column("Target Platform Service", style="info")
        table.add_column("Resolved Live URL Path", style="white")
        
        saved_urls = []
        for platform, url in active_matches:
            table.add_row(platform, url)
            saved_urls.append(url)
            
        console.print(table)
        SESSION_DATA["username_hunter"][username] = saved_urls
        log_success(f"Sweep complete. Discovered {len(active_matches)} positive nodes.")
    else:
        log_warning("No clear resource records located across common top-tier platforms.")

