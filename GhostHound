# MODULE 2: PHONE NUMBER LOOKUP
# -------------------------------------------------------------------------
def phone_lookup():
    print(Fore.CYAN + "\n[+] Phone Number Intelligence Module")
    import phonenumbers
    from phonenumbers import geocoder, carrier, timezone
    
    number = input("Enter phone number with country code (e.g., +1234567890): ").strip()
    try:
        parsed_num = phonenumbers.parse(number)
        if phonenumbers.is_valid_number(parsed_num):
            location = geocoder.description_for_number(parsed_num, "en")
            isp = carrier.name_for_number(parsed_num, "en")
            zones = timezone.time_zones_for_number(parsed_num)
            
            res_data = {
                "Valid": True,
                "Location Context": location if location else "Unknown Country/Region",
                "Carrier/ISP Provider": isp if isp else "Unknown Infrastructure Operator",
                "Timezones": list(zones) if zones else "N/A"
            }
            print(Fore.GREEN + f"\n[Validated Results for {number}]:")
            for k, v in res_data.items():
                print(f" {Fore.WHITE}* {Fore.CYAN}{k}: {Fore.YELLOW}{v}")
            log_result(f"Phone Lookup ({number})", res_data)
        else:
            print(Fore.RED + "[-] Format invalid or unallocated telephone network range.")
    except Exception as e:
        print(Fore.RED + f"[-] Validation Exception Encountered: {e}")
    input("\nPress Enter to return to main menu...")

