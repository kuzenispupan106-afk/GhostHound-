        info = {
            "Title Configuration": soup.title.string.strip() if soup.title else "Null String",
            "Server Infrastructure": res.headers.get('Server', 'Hidden / Cloudflare Protected'),
            "X-Powered-By": res.headers.get('X-Powered-By', 'Not Disclosed'),
            "Security Deployments": {h: res.headers.get(h, "MISSING") for h in ['X-Frame-Options', 'Content-Security-Policy', 'Strict-Transport-Security', 'X-Content-Type-Options']}
        }
        
        print(Fore.GREEN + "\n[Deployment Assessment Summary]:")
