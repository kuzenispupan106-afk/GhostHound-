        print(f" - Application stack:      {Fore.YELLOW}{info['X-Powered-By']}")
        print(Fore.CYAN + "\n[Security Header Audit]:")
        for h, status in info["Security Deployments"].items():
            color = Fore.GREEN if status != "MISSING" else Fore.RED
            print(f"  * {h}: {color}{status}")
            
        log_result(f"Website Analysis ({target_url})", info)
    except Exception as e:
        print(Fore.RED + f"[-] Analysis termination due to runtime error: {e}")
    input("\nPress Enter to return to main menu...")

# -------------------------------------------------------------------------
# MODULE 6: DNS & WHOIS DOMAIN MAPPING
# -------------------------------------------------------------------------
def dns_whois():
    print(Fore.CYAN + "\n[+] DNS Zone Resolution & WHOIS Data Footprinting")
    domain = input("Enter target apex domain (e.g., targetdomain.com): ").strip()
    if not domain or "://" in domain:
        print(Fore.RED + "[-] Error: Enter a raw domain name without protocol descriptors.")
        time.sleep(1.5)
        return
    
    recon_data = {}
    try:
        print(Fore.YELLOW + "[*] Fetching primary network zoning matrices (A, AAAA, MX, TXT, NS)...")
        records = ['A', 'AAAA', 'MX', 'TXT', 'NS']
        dns_res = {}
        for r in records:
            try:
                answers = dns.resolver.resolve(domain, r)
                dns_res[r] = [str(data) for data in answers]
            except:
                dns_res[r] = ["No Records Indexed"]
        
        print(Fore.YELLOW + "[*] Querying network registration allocation data layer...")
        w = whois.whois(domain)
        
        recon_data["DNS Records Map"] = dns_res
        recon_data["Registrar Authority"] = w.registrar if w.registrar else "Private"
        recon_data["Organization Entity"] = w.org if w.org else "Redacted for Privacy"
        recon_data["Country Origin"] = w.country if w.country else "Unknown"
        recon_data["Registration Expiry"] = str(w.expiration_date)
        
        print(Fore.GREEN + "\n[Infrastructure Mapping Layer Data]:")
        print(f" - Registrar Entity:    {Fore.YELLOW}{recon_data['Registrar Authority']}")
        print(f" - Registered Country:   {Fore.YELLOW}{recon_data['Country Origin']}")
        print(f" - Domain Expiry Date:  {Fore.YELLOW}{recon_data['Registration Expiry']}")
        
        print(Fore.CYAN + "\n[Resolved Domain Name Server Vectors]:")
        for record_type, values in dns_res.items():
            print(f"  {Fore.WHITE}Type {record_type}: {Fore.YELLOW}{', '.join(values)}")
            
        log_result(f"DNS & WHOIS ({domain})", recon_data)
    except Exception as e:
        print(Fore.RED + f"[-] Mapping error exception caught: {e}")
    input("\nPress Enter to return to main menu...")

