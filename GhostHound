def ip_intel():
    print(Fore.CYAN + "\n[+] IP Intelligence Module")
    ip = input("Enter Target IP Address: ").strip()
    if not ip: return
    
    url = f"https://ipinfo.io/{ip}/json"
    if IPINFO_TOKEN:
        url += f"?token={IPINFO_TOKEN}"
        
    try:
        res = requests.get(url).json()
        print(Fore.GREEN + f"\n[Results for {ip}]:")
        table = Table(title=f"IP Intel: {ip}")
        table.add_column("Parameter", style="cyan")
        table.add_column("Data Layer", style="magenta")
        
        for k, v in res.items():
            table.add_row(str(k), str(v))
        console.print(table)
        log_result(f"IP Intel ({ip})", res)
    except Exception as e:
        print(Fore.RED + f"[-] Data retrieval error: {e}")
    input("\nPress Enter to return to main menu...")

